---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ABOUT } from '../config';
---

<BaseLayout title="aboutme">
  <h1>// about</h1>

  <div class="panel">
    <!-- Edit ABOUT in src/config.ts -->
    <p class="intro">{ABOUT.intro}</p>

    <hr />

    <dl class="contact-list">
      {ABOUT.links.map(link => (
        <div class="contact-row">
          <dt>{link.label}</dt>
          <dd><a href={link.href} target="_blank" rel="noopener noreferrer">{link.href}</a></dd>
        </div>
      ))}
    </dl>
  </div>
</BaseLayout>

<style>
  h1 {
    color: var(--text-dim);
    font-weight: 400;
    font-size: 0.88rem;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .intro {
    white-space: pre-line;
    color: var(--text);
    margin-bottom: 0;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-row {
    display: flex;
    gap: 1.5rem;
  }

  dt {
    color: var(--text-dim);
    min-width: 6rem;
    flex-shrink: 0;
  }

  dd {
    color: var(--text);
  }
</style>
