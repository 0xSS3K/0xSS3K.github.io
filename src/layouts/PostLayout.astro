---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
}

const { title, date, description, tags = [] } = Astro.props;

const dateStr = date.toISOString().slice(0, 10).replace(/-/g, '.');
const tagStr  = tags.map(t => `tag:${t}`).join(' // ');
const meta    = [dateStr, tagStr].filter(Boolean).join(' // ');
---

<BaseLayout title={title} description={description}>
  <article class="prose">
    <header class="post-header">
      <h1>{title}</h1>
      <p class="post-meta">{meta}</p>
    </header>
    <slot />
  </article>
</BaseLayout>

<style>
  .post-header {
    border-bottom: 1px solid var(--border);
    margin-top: 2.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
  }

  /* ── Prose overrides for post bodies ──────────────────────────── */
  .prose :global(h2) { margin-top: 2.5rem; }
  .prose :global(h3) { margin-top: 2rem; }
  .prose :global(a)  { color: var(--accent); }
  .prose :global(a:hover) { color: var(--text-bold); }

  /* Shiki code blocks: ensure they stretch to panel width */
  .prose :global(pre) {
    margin-left: -1px;
    margin-right: -1px;
  }
</style>
